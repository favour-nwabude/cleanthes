<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    Shown every launch after first setup.

    STOIC DESIGN:
    - No warning card — they acknowledged once. That is enough.
    - No memento mori divider — this screen is about speed, not ceremony.
    - "The gate does not ask twice." — consequence without lecture.
    - Minimal. The discipline is in what is removed, not what is added.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cleanthes_black"
    android:paddingStart="28dp"
    android:paddingEnd="28dp">

    <!-- ImageView — NOT ImageButton. ImageButton adds a default background box. -->
    <ImageView
        android:id="@+id/login_icon_lock"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_lock"
        android:tint="@color/citadel_gold"
        android:contentDescription="@string/cd_cleanthes_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/login_tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.36" />

    <TextView
        android:id="@+id/login_tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/cleanthes_text_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/login_icon_lock"
        app:layout_constraintBottom_toTopOf="@id/login_tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/login_tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_subtitle"
        android:textColor="@color/cleanthes_text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/login_tv_title"
        app:layout_constraintBottom_toTopOf="@id/login_label_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/login_label_password"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/cleanthes_text_secondary"
        android:text="@string/login_label_password"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/login_tv_subtitle"
        app:layout_constraintBottom_toTopOf="@id/login_container_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/login_container_password"
        android:layout_height="wrap_content"
        android:layout_width="0dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        app:layout_constraintTop_toBottomOf="@id/login_label_password"
        app:layout_constraintBottom_toTopOf="@id/login_tv_error"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/login_et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_master_password"
            android:textColorHint="@color/cleanthes_disabled"
            android:textColor="@color/cleanthes_text_primary"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="52dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:background="@null"
            android:imeOptions="actionDone"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/login_btn_toggle_password"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:src="@drawable/ic_eye_off"
            android:tint="@color/cleanthes_text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_toggle_password_visibility"
            android:padding="12dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/login_tv_error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/cleanthes_error"
        android:textSize="13sp"
        android:visibility="gone"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/login_container_password"
        app:layout_constraintBottom_toTopOf="@id/login_tv_attempts"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/login_tv_attempts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/cleanthes_warning"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/login_tv_error"
        app:layout_constraintBottom_toTopOf="@id/login_btn_unlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AUTHENTICATE — gold, consistent with FORTIFY on setup screen -->
    <Button
        android:id="@+id/login_btn_unlock"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/login_btn_unlock"
        android:textColor="@color/cleanthes_black"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="@color/citadel_gold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/login_tv_attempts"
        app:layout_constraintBottom_toTopOf="@id/login_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/login_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/cleanthes_border"
        android:layout_marginTop="28dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/login_btn_unlock"
        app:layout_constraintBottom_toTopOf="@id/login_tv_biometric_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/login_tv_biometric_hint"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="@string/login_biometric_hint"
        android:textColor="@color/cleanthes_text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/login_divider"
        app:layout_constraintBottom_toTopOf="@id/login_btn_biometric"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/login_btn_biometric"
        android:layout_height="64dp"
        android:layout_width="64dp"
        android:tint="@color/citadel_gold"
        android:background="@drawable/bg_biometric_button"
        android:contentDescription="@string/cd_fingerprint_icon"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/login_tv_biometric_hint"
        app:layout_constraintBottom_toTopOf="@id/login_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/login_progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="@color/citadel_gold"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/login_btn_biometric"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Accent rule — same width as splash, consistent visual language -->
    <View
        android:id="@+id/login_quote_divider"
        android:layout_width="40dp"
        android:layout_height="1dp"
        android:background="@color/cleanthes_accent"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/login_tv_quote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Stoic quote -->
    <TextView
        android:id="@+id/login_tv_quote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="The willing are led by fate;\nthe unwilling are dragged."
        android:textColor="@color/cleanthes_text_secondary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-light"
        android:textStyle="italic"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/login_tv_quote_attribution"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Attribution -->
    <TextView
        android:id="@+id/login_tv_quote_attribution"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="— Cleanthes of Assos"
        android:textColor="@color/cleanthes_accent_dim"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toTopOf="@id/login_tv_brand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brand footer — pinned to screen bottom, consistent with setup -->
    <TextView
        android:id="@+id/login_tv_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_brand"
        android:textColor="@color/cleanthes_disabled"
        android:textSize="10sp"
        android:letterSpacing="0.25"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
