<?xml version="1.0" encoding="utf-8"?>
<!--
activity_setup.xml
Shown exactly ONCE on first launch.

STOIC DESIGN NOTES:
- "Your Inner Citadel"    → Marcus Aurelius. The mind as inviolable fortress.
- "memento mori" divider  → Remember death. Password loss is permanent.
- Checkbox acknowledgment → Consent with intention, not ignorance.
- "FORTIFY"               → Build strength. Not just lock a door.
- FLAG_SECURE             → No screenshots. No recents preview. Non-negotiable.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cleanthes_black"
    android:fillViewport="true"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- ── LOCK ICON ───────────────────────────────────────── -->
        <ImageView
            android:id="@+id/setup_icon_lock"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/citadel_gold"
            android:contentDescription="@string/cd_cleanthes_logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── APP NAME ─────────────────────────────────────────── -->
        <TextView
            android:id="@+id/setup_tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/cleanthes_text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/setup_icon_lock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── SUBTITLE ─────────────────────────────────────────── -->
        <TextView
            android:id="@+id/setup_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/cleanthes_text_secondary"
            android:textSize="14sp"
            android:letterSpacing="0.04"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/setup_tv_app_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── MEMENTO MORI DIVIDER ─────────────────────────────── -->
        <!--
            Two thin lines flanking the latin text.
            Positioned as a philosophical section break, not decoration.
        -->
        <LinearLayout
            android:id="@+id/setup_divider_memento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/setup_tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_memento_mori"
                android:textColor="@color/cleanthes_text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_border" />

        </LinearLayout>

        <!-- ── WARNING CARD ─────────────────────────────────────── -->
        <!--
            Orange border retained — signals urgency without red alarm.
            Checkbox at bottom: forces conscious acknowledgment.
            A user who taps without reading still made a deliberate gesture.
        -->
        <LinearLayout
            android:id="@+id/setup_card_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_warning_card"
            app:layout_constraintTop_toBottomOf="@id/setup_divider_memento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_warning_title"
                android:textColor="@color/cleanthes_warning"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_warning_body"
                android:textColor="@color/cleanthes_text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

            <!-- Thin separator before the checkbox -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cleanthes_border"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp" />

            <!-- Acknowledgment — FORTIFY button is dead until this is checked -->
            <CheckBox
                android:id="@+id/setup_cb_acknowledge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_warning_acknowledge"
                android:textColor="@color/cleanthes_text_secondary"
                android:textSize="13sp"
                android:buttonTint="@color/cleanthes_warning"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- ── MASTER PASSWORD LABEL ────────────────────────────── -->
        <TextView
            android:id="@+id/setup_label_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_label_password"
            android:textColor="@color/cleanthes_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/setup_card_warning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── MASTER PASSWORD INPUT ────────────────────────────── -->
        <FrameLayout
            android:id="@+id/setup_container_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            app:layout_constraintTop_toBottomOf="@id/setup_label_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/setup_et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_master_password"
                android:textColorHint="@color/cleanthes_disabled"
                android:textColor="@color/cleanthes_text_primary"
                android:textSize="16sp"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:background="@null"
                android:imeOptions="actionNext"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/setup_btn_toggle_password"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:src="@drawable/ic_eye_off"
                android:tint="@color/cleanthes_text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_toggle_password_visibility"
                android:padding="12dp" />
        </FrameLayout>

        <!-- ── STRENGTH BAR ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/setup_strength_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/setup_container_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:id="@+id/setup_strength_seg1"
                android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_strength_empty"
                android:layout_marginEnd="3dp" />
            <View android:id="@+id/setup_strength_seg2"
                android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_strength_empty"
                android:layout_marginEnd="3dp" />
            <View android:id="@+id/setup_strength_seg3"
                android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_strength_empty"
                android:layout_marginEnd="3dp" />
            <View android:id="@+id/setup_strength_seg4"
                android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_strength_empty"
                android:layout_marginEnd="3dp" />
            <View android:id="@+id/setup_strength_seg5"
                android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/cleanthes_strength_empty" />

        </LinearLayout>

        <!-- Strength label: "Extremely Vulnerable" → "Impenetrable" -->
        <TextView
            android:id="@+id/setup_tv_strength_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/cleanthes_text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/setup_strength_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── CONFIRM PASSWORD LABEL ───────────────────────────── -->
        <TextView
            android:id="@+id/setup_label_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_label_confirm"
            android:textColor="@color/cleanthes_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/setup_tv_strength_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── CONFIRM PASSWORD INPUT ───────────────────────────── -->
        <FrameLayout
            android:id="@+id/setup_container_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            app:layout_constraintTop_toBottomOf="@id/setup_label_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/setup_et_confirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_confirm_password"
                android:textColorHint="@color/cleanthes_disabled"
                android:textColor="@color/cleanthes_text_primary"
                android:textSize="16sp"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:background="@null"
                android:imeOptions="actionDone"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/setup_btn_confirm"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:src="@drawable/ic_eye_off"
                android:tint="@color/cleanthes_text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/toggle_password_visibility"
                android:padding="12dp" />
        </FrameLayout>

        <!-- Match indicator -->
        <TextView
            android:id="@+id/setup_tv_match_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/setup_container_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── ERROR MESSAGE ─────────────────────────────────────── -->
        <TextView
            android:id="@+id/setup_tv_error"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/cleanthes_error"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/setup_tv_match_indicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── FORTIFY BUTTON ────────────────────────────────────── -->
        <!--
            Gold. Disabled until checkbox is checked.
            Alpha and enabled state managed entirely from SetupActivity.
            backgroundTint is forced programmatically to prevent Material
            Button from overriding gold with its internal disabled gray.
        -->
        <Button
            android:id="@+id/setup_btn_create"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/setup_btn_create"
            android:textColor="@color/cleanthes_black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:backgroundTint="@color/citadel_gold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/setup_tv_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── PROGRESS BAR ──────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/setup_progress"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="@color/citadel_gold"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/setup_btn_create"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── BRAND FOOTER (pinned to screen bottom) ───────────── -->
        <TextView
            android:id="@+id/setup_tv_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_brand"
            android:textColor="@color/cleanthes_disabled"
            android:textSize="10sp"
            android:letterSpacing="0.25"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
