<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_detail.xml
    Read-only entry view. No editing here — tap EDIT to go to AddEditActivity.

    DESIGN:
    - Toolbar title = entry name (set dynamically)
    - Category shown as secondary label below divider
    - Password hidden by default — eye toggle + copy
    - Website/Notes/Favorite shown only when present (visibility="gone" by default)
    - Copy buttons gold — consistent with the rest of the app
-->
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@color/cleanthes_black">

	<!-- ── TOOLBAR ────────────────────────────────────────────── -->
	<androidx.constraintlayout.widget.ConstraintLayout
		android:id="@+id/detail_toolbar"
		android:layout_width="match_parent"
		android:layout_height="56dp"
		android:paddingStart="4dp"
		android:paddingEnd="8dp">

		<ImageButton
			android:id="@+id/detail_btn_back"
			android:layout_width="44dp"
			android:layout_height="44dp"
			android:src="@drawable/ic_arrow_back"
			android:tint="@color/cleanthes_text_primary"
			android:background="?attr/selectableItemBackgroundBorderless"
			android:contentDescription="Go back"
			android:padding="10dp"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent" />

		<!-- Title set dynamically to entry name -->
		<TextView
			android:id="@+id/detail_tv_toolbar_title"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="ENTRY"
			android:textColor="@color/cleanthes_text_primary"
			android:textSize="18sp"
			android:textStyle="bold"
			android:textAllCaps="true"
			android:letterSpacing="0.1"
			android:maxLines="1"
			android:ellipsize="end"
			android:layout_marginStart="4dp"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toEndOf="@id/detail_btn_back"
			app:layout_constraintEnd_toStartOf="@id/detail_btn_edit" />

		<Button
			android:id="@+id/detail_btn_edit"
			android:layout_width="wrap_content"
			android:layout_height="36dp"
			android:text="EDIT"
			android:textColor="@color/cleanthes_black"
			android:textSize="13sp"
			android:textStyle="bold"
			android:letterSpacing="0.1"
			android:backgroundTint="@color/citadel_gold"
			android:paddingStart="16dp"
			android:paddingEnd="16dp"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent" />

	</androidx.constraintlayout.widget.ConstraintLayout>

	<!-- Toolbar divider -->
	<View
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="@color/cleanthes_border" />

	<!-- ── SCROLLABLE CONTENT ──────────────────────────────────── -->
	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:scrollbars="none"
		android:fillViewport="true">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:paddingStart="20dp"
			android:paddingEnd="20dp"
			android:paddingTop="20dp"
			android:paddingBottom="40dp">

			<!-- Category (shown at top, small, secondary) -->
			<TextView
				android:id="@+id/detail_tv_category"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textColor="@color/cleanthes_text_secondary"
				android:textSize="11sp"
				android:letterSpacing="0.12"
				android:textAllCaps="true" />

			<View
				android:layout_width="match_parent"
				android:layout_height="1dp"
				android:background="@color/cleanthes_border"
				android:layout_marginTop="16dp"
				android:layout_marginBottom="4dp" />

			<!-- ── USERNAME ──────────────────────────────────── -->
			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="USERNAME / EMAIL"
				android:textColor="@color/cleanthes_text_secondary"
				android:textSize="11sp"
				android:letterSpacing="0.12"
				android:layout_marginTop="16dp" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:gravity="center_vertical"
				android:layout_marginTop="4dp">

				<TextView
					android:id="@+id/detail_tv_username"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:textColor="@color/cleanthes_text_primary"
					android:textSize="16sp"
					android:textIsSelectable="true" />

				<ImageButton
					android:id="@+id/detail_btn_copy_username"
					android:layout_width="44dp"
					android:layout_height="44dp"
					android:src="@drawable/ic_copy"
					android:tint="@color/citadel_gold"
					android:background="?attr/selectableItemBackgroundBorderless"
					android:contentDescription="Copy username"
					android:padding="10dp" />

			</LinearLayout>

			<!-- ── PASSWORD ──────────────────────────────────── -->
			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="PASSWORD"
				android:textColor="@color/cleanthes_text_secondary"
				android:textSize="11sp"
				android:letterSpacing="0.12"
				android:layout_marginTop="20dp" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:gravity="center_vertical"
				android:layout_marginTop="4dp">

				<TextView
					android:id="@+id/detail_tv_password"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="••••••••••••"
					android:textColor="@color/cleanthes_text_primary"
					android:textSize="16sp"
					android:fontFamily="monospace"
					android:textIsSelectable="true" />

				<!-- Eye toggle — secondary color (not gold, not primary CTA) -->
				<ImageButton
					android:id="@+id/detail_btn_toggle_password"
					android:layout_width="44dp"
					android:layout_height="44dp"
					android:src="@drawable/ic_eye_off"
					android:tint="@color/cleanthes_text_secondary"
					android:background="?attr/selectableItemBackgroundBorderless"
					android:contentDescription="Show or hide password"
					android:padding="10dp" />

				<ImageButton
					android:id="@+id/detail_btn_copy_password"
					android:layout_width="44dp"
					android:layout_height="44dp"
					android:src="@drawable/ic_copy"
					android:tint="@color/citadel_gold"
					android:background="?attr/selectableItemBackgroundBorderless"
					android:contentDescription="Copy password"
					android:padding="10dp" />

			</LinearLayout>

			<!-- ── WEBSITE (conditional) ──────────────────────── -->
			<TextView
				android:id="@+id/detail_label_website"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="WEBSITE"
				android:textColor="@color/cleanthes_text_secondary"
				android:textSize="11sp"
				android:letterSpacing="0.12"
				android:layout_marginTop="20dp"
				android:visibility="gone" />

			<TextView
				android:id="@+id/detail_tv_website"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:textColor="@color/citadel_gold"
				android:textSize="15sp"
				android:textIsSelectable="true"
				android:layout_marginTop="4dp"
				android:visibility="gone" />

			<!-- ── NOTES (conditional) ────────────────────────── -->
			<TextView
				android:id="@+id/detail_label_notes"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="NOTES"
				android:textColor="@color/cleanthes_text_secondary"
				android:textSize="11sp"
				android:letterSpacing="0.12"
				android:layout_marginTop="20dp"
				android:visibility="gone" />

			<TextView
				android:id="@+id/detail_tv_notes"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:textColor="@color/cleanthes_text_primary"
				android:textSize="15sp"
				android:textIsSelectable="true"
				android:lineSpacingExtra="4dp"
				android:layout_marginTop="4dp"
				android:visibility="gone" />

			<!-- ── PRIORITY INDICATOR (conditional) ──────────── -->
			<TextView
				android:id="@+id/detail_tv_favorite"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="★  Priority entry"
				android:textColor="@color/citadel_gold"
				android:textSize="13sp"
				android:layout_marginTop="24dp"
				android:visibility="gone" />

		</LinearLayout>
	</ScrollView>

</LinearLayout>
